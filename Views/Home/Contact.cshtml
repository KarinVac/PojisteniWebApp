@{
    ViewData["Title"] = "Kontakt";
}

<div class="container mt-4">

    <div class="mb-5">
        <p class="lead text-muted">
            Máte dotaz nebo potřebujete poradit s výběrem pojištění? Jsme tu pro vás.
        </p>
    </div>

    <div class="row mb-5">
        <!-- Telefon -->
        <div class="col-md-6 mb-4 mb-md-0">
            <h4 class="mb-1">Zákaznická linka</h4>
            <p class="fs-4 fw-semibold mb-1">
                <a href="tel:+420123456789" class="text-decoration-none contact-link">
                    +420&nbsp;123&nbsp;456&nbsp;789
                </a>
            </p>
            <p class="text-muted">PO–PÁ: 8:00 – 18:00</p>
        </div>

        <!-- Email -->
        <div class="col-md-6">
            <h4 class="mb-1">E-mail</h4>
            <p class="mb-1">
                Napište nám na
                <a href="mailto:info@kvinsurance.cz" class="contact-link">
                    info@kvinsurance.cz
                </a>
            </p>
            <p class="text-muted">Odpovídáme zpravidla do 24 hodin v pracovních dnech.</p>
        </div>
    </div>

    <!-- Formulář -->
    <div class="row">
        <div class="col-md-8">
            <h4 class="mb-2">Napište nám</h4>
            <p class="text-muted mb-3">
                Nebo využijte náš kontaktní formulář, odpovíme vám co nejdříve.
            </p>
            <iframe frameborder="0" scrolling="no" width="100%" height="380"
                    style="border: 1px solid #ddd; border-radius: 6px;"
                    src="https://www.itnetwork.cz/service/mail_form.php?hash=5b5a8cdab989b5e4833544f23501910b">
            </iframe>
        </div>
    </div>

    </div>

</div>
