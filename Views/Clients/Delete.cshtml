@model PojisteniWebApp.Models.ClientViewModel


@{
    ViewData["Title"] = "Odstranění";
}
<p class="mt-3">Opravdu chcete odstranit pojištěnce <b>@Model.FirstName @Model.LastName</b>?</p>

<form class="py-1" asp-action="Delete" asp-route-id="@Model.Id">
    <button class="primary-button" type="submit">Odstranit</button>
    <a class="primary-button" asp-action="Index">Zpět na přehled</a>
</form>
