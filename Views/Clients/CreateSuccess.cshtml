@model PojisteniWebApp.Models.ClientViewModel

@{
    ViewData["Title"] = "Pojištěnec vytvořen";
}

<div class="success-card">
    <h2>Pojištěnec vytvořen</h2>
    <p>Nový klient <strong>@ViewBag.NewClientName</strong> byl úspěšně založen v databázi.</p>
    <h4>Chcete přidat pojištění?</h4>
    <div class="buttons">
        <a asp-controller="Insurances" asp-action="Create" asp-route-clientId="@ViewBag.NewClientId" class="btn btn-primary btn-lg">
            Ano
        </a>
        <a asp-controller="Clients" asp-action="Index" class="btn btn-secondary btn-lg ml-2">
            Ne
        </a>
    </div>
</div>

