@model PojisteniWebApp.Models.ClientViewModel

@{
    ViewData["Title"] = "Detail pojištěnce";
}

<section class="page-section">
    <div class="container d-flex justify-content-center">
        <div class="mx-auto" style="max-width:500px; width:100%;">
            <h2 class="text-center mb-4">@ViewData["Title"]</h2>

            <div class="card shadow p-4 mb-4">
                <div class="card-body">
                    <p><strong>Jméno a přijmení:</strong> @Model.FullName</p>
                    <p><strong>Email:</strong> @Model.Email</p>
                    <p><strong>Telefon:</strong> @Model.PhoneNumber</p>
                    <p><strong>Adresa:</strong> @Model.Street, @Model.City, @Model.Zip</p>

                    <div class="mt-3">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                            Editovat
                        </a>
                        <a asp-action="Index" class="btn btn-secondary ms-2">
                            Zpět na seznam
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
