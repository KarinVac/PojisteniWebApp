@model PojisteniWebApp.Models.ClientViewModel

@{
    ViewData["Title"] = "Detail pojištěnce";
}

<div class="row">
   
    <div class="col-md-8">
        <h4>@Model.FullName</h4>
        <dl class="row">
            <dt class="col-sm-3">Adresa:</dt>
            <dd class="col-sm-9">@Model.Street, @Model.City, @Model.Zip</dd>

            <dt class="col-sm-3">Telefon:</dt>
            <dd class="col-sm-9">@Model.PhoneNumber</dd>

            <dt class="col-sm-3">Email:</dt>
            <dd class="col-sm-9">@Model.Email</dd>
        </dl>
    </div>

   
    <div class="col-md-4 text-center">
        <img src="~/images/user_logo.png" class="img-fluid rounded mb-3" alt="Profilová fotka" style="max-width: 150px;" />
    </div>
</div>

<hr class="mt-4 mb-4" /> 


<div class="row">
    <div class="col-12">        
        <h4>Sjednaná pojištění</h4>

        @if (Model.Insurances.Any())
        {
            <table class="table table-striped mt-3">
                <thead>
                    <tr>
                        <th>Předmět</th>
                        <th>Částka</th>
                        <th>Platnost od</th> 
                        <th>Platnost do</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var insurance in Model.Insurances)
                    {
                        <tr>
                            <td>@insurance.Type</td>
                            <td>@insurance.Amount.ToString("N0") Kč</td>
                            <td>@insurance.StartDate.ToShortDateString()</td>
                            <td>@insurance.EndDate.ToShortDateString()</td>
                            <td class="action-links">
                                <a asp-controller="Insurances" asp-action="Details" asp-route-id="@insurance.Id">Detail</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p>Klient zatím nemá sjednané žádné pojištění.</p>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-controller="Insurances" asp-action="Create" asp-route-clientId="@Model.Id" class="btn btn-primary">Přidat nové pojištění</a>
    <a asp-action="Index" class="btn btn-secondary">Zpět na přehled</a>
</div>